    "last_edited_by": {
      "object": "user",
      "id": "fa626e5b-d1fc-42ce-9394-3d5014e1bebd"
    },
    "has_children": false,
    "archived": false,
    "in_trash": false,
    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "Over the past three months, the number of stray cats living around our office building has grown from 5 to over 30. During my breaks, I often go downstairs to check on the kittens. One day while feeding them, I witnessed a woman capturing the cats. She told me she would be sending them all to be spayed and neutered. I was familiar with the TNR (Trap-Neuter-Return) concept, but had never helped with it before. I asked her if I could get involved, and that's how I get to know Chen.",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "Over the past three months, the number of stray cats living around our office building has grown from 5 to over 30. During my breaks, I often go downstairs to check on the kittens. One day while feeding them, I witnessed a woman capturing the cats. She told me she would be sending them all to be spayed and neutered. I was familiar with the TNR (Trap-Neuter-Return) concept, but had never helped with it before. I asked her if I could get involved, and that's how I get to know Chen.",
          "href": null
        }
      ],
      "color": "default"
    }
  },
