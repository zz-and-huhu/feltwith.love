    "has_children": false,
    "in_trash": false,
    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "In March 2025, Britt flew to Shanghai and we met in person. I handed her the two finished portraits. She held them up next to her phone photos and just looked back and forth for a while. That moment is the reason I do this work. Not because of anything dramatic, but because I could tell she recognized them. They looked like her cats.",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "In March 2025, Britt flew to Shanghai and we met in person. I handed her the two finished portraits. She held them up next to her phone photos and just looked back and forth for a while. That moment is the reason I do this work. Not because of anything dramatic, but because I could tell she recognized them. They looked like her cats.",
          "href": null
        }
      ],
      "icon": null,
      "color": "default"
