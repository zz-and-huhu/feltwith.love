    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "There are moments in life when a single thread of trust unravels into something extraordinary. For me, that thread began with a needle, some wool, and a stranger named Britt Schiks.",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
