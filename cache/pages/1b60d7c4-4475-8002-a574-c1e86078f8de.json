      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "When she mentioned she’d be visiting Shanghai the following year, it gave me lots of time—time to pour into every tuft of fur, every glint in their eyes. With each poke of the needle, I felt the weight of her trust. This wasn’t just about shaping wool; it was about weaving love into something you could hold.",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
