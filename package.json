{
  "name": "startup-nextjs-template",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "pnpm refresh-cache && mkdir -p public/images && cp -r cache/images/* public/images && next build",
    "refresh-cache": "pnpm exec tsx scripts/refresh-cache.ts",
    "format": "prettier --write \"**/*.{js,jsx,json,ts,tsx,md,mdx,css,html,yml,yaml,scss,sass}\" --ignore-path .gitignore",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "@next/font": "13.1.6",
    "@notion-render/bookmark-plugin": "^0.0.2",
    "@notion-render/client": "^0.0.2",
    "@notion-render/hljs-plugin": "^0.0.2",
    "@notionhq/client": "^2.2.16",
    "clsx": "^2.1.1",
    "dotenv": "^16.4.7",
    "eslint": "8.33.0",
    "eslint-config-next": "13.1.6",
    "katex": "0.12.0",
    "less": "^4.2.0",
    "less-loader": "^12.2.0",
    "next": "^15.2.1",
    "next-themes": "^0.2.1",
    "rc-pagination": "^4.2.0",
    "react": "18.2.0",
    "react-cusdis": "^2.1.3",
    "react-dom": "18.2.0",
    "react-modal-video": "^2.0.0",
    "react-share": "^5.1.0",
    "server-only": "^0.0.1",
    "undici": "5.28.4",
    "image-size": "^1.2.0",
    "p-limit": "^6.2.0",
    "commander": "^13.0.0"
  },
  "devDependencies": {
    "@types/katex": "0.11.0",
    "@types/node": "^18.15.11",
    "@types/react": "^18.0.34",
    "autoprefixer": "^10.4.13",
    "postcss": "^8.4.21",
    "prettier": "^2.8.3",
    "prettier-plugin-tailwindcss": "^0.2.2",
    "react-share": "^5.1.0",
    "tailwindcss": "^3.3.3",
    "tsx": "^4.19.3",
    "typescript": "^5.0.4"
  },
  "overrides": {
    "undici": "5.28.4"
  }
}
